DISCORD_BOT_TOKEN=your_discord_bot_token_here
VOICE_CHANNEL_ID=123456789012345678
WEBHOOK_URL=https://your-backend.example.com/webhooks/discord-voice
WEBHOOK_SECRET=optional_shared_secret
JULGAR_CHANNEL_ID=123456789012345679

# Google Calendar (opcional)
# 1. Crie um projeto no Google Cloud Console
# 2. Ative a Google Calendar API
# 3. Crie credenciais OAuth 2.0 (tipo: Web application)
# 4. Adicione a redirect URI: http://localhost:8080/oauth2callback
# 5. Copie o Client ID e Client Secret abaixo
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Canal de texto onde os comandos !agendar, !eventos, !cancelar funcionarao
# (opcional: se omitido, usa JULGAR_CHANNEL_ID)
CALENDAR_CHANNEL_ID=
# URI de redirecionamento OAuth (deve ser igual ao registrado no Google Cloud)
CALENDAR_REDIRECT_URI=http://localhost:8080/oauth2callback
# Porta local para o servidor de callback OAuth
CALENDAR_OAUTH_PORT=8080
# Fuso horario usado ao criar eventos
CALENDAR_TIMEZONE=America/Sao_Paulo
